# Frontend Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase configuration (optional for auth/other server usage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Postgres DATABASE_URL for Prisma
# Example: postgresql://postgres:password@db.host.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres?sslmode=require

# Local API URL for client-side requests
NEXT_PUBLIC_API_URL=http://localhost:4000
